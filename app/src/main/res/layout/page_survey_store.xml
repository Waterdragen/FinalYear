<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".PageSurveyStore">

    <TextView
        android:id="@+id/textSurveyStoreTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Survey Store"
        android:gravity="center"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:background="@color/greenTint"
        android:padding="5dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <LinearLayout
        android:id="@+id/frameSurveyStore"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:weightSum="12"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSurveyStoreTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/frameSurveyConfig"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textLoadedFile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Loaded file: "
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/textNumNavSat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Navigation satellite count: "
                android:textSize="20sp"
                app:layout_constraintTop_toBottomOf="@id/textSurveyStoreTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/textNumObs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number of observations: "
                android:textSize="20sp"
                app:layout_constraintTop_toBottomOf="@id/textSurveyStoreTitle"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadCsv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Load CSV"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:layout_margin="10dp"
                    android:backgroundTint="@color/gray_100"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/gray_600"
                    app:cornerRadius="5dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCalculate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculate"
                    android:textSize="20sp"
                    android:textColor="@color/black"
                    android:layout_margin="10dp"
                    android:backgroundTint="@color/gray_100"
                    app:strokeWidth="2dp"
                    app:strokeColor="@color/gray_600"
                    app:cornerRadius="5dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    />
            </androidx.constraintlayout.widget.ConstraintLayout>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/frameSurveyData"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="5"
            android:baselineAligned="false"
            android:weightSum="2"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textSurveyStoreTitle">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_weight="1">

                <!-- Horizontal rule -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@color/black"/>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPP Only"
                    android:textSize="20sp"/>

                <!-- Horizontal rule -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@color/black"/>

                <!-- SPP Results -->
                <TextView
                    android:id="@+id/textSppResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"/>

                <!-- SPP Diff Results -->
                <TextView
                    android:id="@+id/textSppDiffResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20sp"
                    android:textSize="18sp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_weight="1">

                <!-- Horizontal rule -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@color/black"/>

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:text="With DGNSS"/>

                <!-- Horizontal rule -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:background="@color/black"/>

                <!-- DGNSS Results -->
                <TextView
                    android:id="@+id/textDgnssResult"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"/>

                <!-- DGNSS Diff Results -->
                <TextView
                    android:id="@+id/textDgnssDiffE"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20sp"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/textDgnssDiffN"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"/>
                <TextView
                    android:id="@+id/textDgnssDiffH"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/frameKnownPos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:orientation="vertical">

            <!-- Horizontal rule -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="5dp"
                android:background="@color/black"/>

            <!-- Station name -->
            <TextView
                android:id="@+id/textStationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Station name:"
                android:textSize="18sp"/>

            <!-- Position -->
            <TextView
                android:id="@+id/textStationPos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coordinates: "
                android:textSize="18sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="10dp">

                <!-- Load stations -->
                <ImageButton
                    android:id="@+id/btnLoadStations"
                    android:layout_width="40sp"
                    android:layout_height="40sp"
                    android:src="@drawable/ic_baseline_attach_file_24"
                    android:background="@drawable/btn_style_primary"
                    android:layout_marginStart="5sp"
                    android:contentDescription="Load stations"
                    app:tint="@color/gray_900" />

                <!-- Change station -->
                <ImageButton
                    android:id="@+id/btnChangeStation"
                    android:layout_width="40sp"
                    android:layout_height="40sp"
                    android:src="@drawable/ic_baseline_autorenew_24"
                    android:background="@drawable/btn_style_primary"
                    android:layout_marginStart="5sp"
                    android:contentDescription="Change station"
                    app:tint="@color/gray_900" />

                <!-- Clear station -->
                <ImageButton
                    android:id="@+id/btnClearStation"
                    android:layout_width="40sp"
                    android:layout_height="40sp"
                    android:src="@drawable/ic_baseline_clear_24"
                    android:background="@drawable/btn_style_primary"
                    android:layout_marginStart="5sp"
                    android:contentDescription="Clear station"
                    app:tint="@color/gray_900" />

            </LinearLayout>

        </LinearLayout>


    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>